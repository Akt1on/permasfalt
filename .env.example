# Copy this file to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon_key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# ─── Server-only (API functions) ──────────────────────────────────────────────
# The service role key bypasses RLS — keep it strictly server-side!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service_key

# ─── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooP
TELEGRAM_CHAT_ID=123456789

# ─── CORS (optional) ──────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://permasfalt59.ru
