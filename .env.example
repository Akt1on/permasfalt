# Supabase — публичные ключи (для фронта, Vite)
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...anon-key...

# Supabase — серверные ключи (только Vercel, не в браузер!)
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# Telegram-бот для уведомлений о заявках
TELEGRAM_BOT_TOKEN=123456789:ABC...
TELEGRAM_CHAT_ID=-100123456789

# CORS — разрешённый origin для API
ALLOWED_ORIGIN=https://permasfalt59.ru

# Bootstrap-флаг — включить ТОЛЬКО при первом деплое,
# сразу после создания первого admin-аккаунта — удалить!
BOOTSTRAP_ADMIN=true
